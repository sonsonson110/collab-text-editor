# Port the WebSocket server listens on
PORT=1234

# Shared HMAC-SHA256 signing key — must be identical to app.jwt.secret in the Spring api-server.
# Override in production via the JWT_SECRET environment variable; never commit the real secret.
JWT_SECRET=

# Shared secret for sync-server → api-server internal calls.
# Must match APP_INTERNAL_API_SECRET (app.internal-api.secret) in the api-server.
INTERNAL_API_SECRET=

# Base URL of the Spring api-server (used for snapshot persistence calls)
API_BASE_URL=http://localhost:8081